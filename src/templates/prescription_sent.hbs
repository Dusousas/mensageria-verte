<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Sua prescrição médica chegou</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f6f1e8;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="24" border="0">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width: 640px; background: #ffffff; border-radius: 14px; overflow: hidden; box-shadow: 0 4px 16px rgba(22, 59, 52, 0.08);">
          <tr>
            <td>
              {{> header preheader="Sua prescrição digital está disponível" appName=appName}}
            </td>
          </tr>
          <tr>
            <td style="padding: 26px 24px 8px 24px; font-family: Inter, Arial, sans-serif; color: #212529;">
              <h1 style="margin: 0 0 12px 0; font-size: 24px; line-height: 31px; color: #163b34;">Sua prescrição chegou</h1>
              <p style="margin: 0; font-size: 15px; line-height: 24px; color: #3c4643;">
                Olá{{#if name}}, {{name}}{{/if}}. {{#if medicoNome}}{{medicoNome}}{{else}}Seu médico{{/if}} emitiu sua prescrição médica e ela já está disponível para download.
              </p>
            </td>
          </tr>
          <tr>
            <td style="padding: 16px 24px 24px 24px;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background: #faf3e8; border: 1px solid #eadfce; border-radius: 10px;">
                <tr>
                  <td style="padding: 14px 16px; font-family: Inter, Arial, sans-serif; font-size: 14px; color: #3c4643;">
                    <strong style="color: #163b34;">Assinado digitalmente com certificado ICP-Brasil.</strong><br />
                    Este documento tem a mesma validade jurídica de uma receita física assinada à mão.
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {{#if pdfUrl}}
          <tr>
            <td style="padding: 0 24px 20px 24px;" align="center">
              <a href="{{pdfUrl}}" style="display: inline-block; background-color: #2a5654; color: #ffffff; text-decoration: none; font-family: Inter, Arial, sans-serif; font-weight: 600; font-size: 14px; line-height: 20px; padding: 14px 28px; border-radius: 10px;">
                Baixar prescrição (PDF)
              </a>
            </td>
          </tr>
          {{/if}}
          <tr>
            <td style="padding: 0 24px 24px 24px; font-family: Inter, Arial, sans-serif; font-size: 13px; color: #6b7573;">
              <p style="margin: 0 0 8px 0;">
                Você também pode consultar suas prescrições a qualquer momento em
                <a href="https://vertebeauty.com.br/account" style="color: #2a5654; text-decoration: underline;">Minha Conta → Prescrições</a>.
              </p>
              <p style="margin: 0;">
                Leve este PDF (impresso ou em seu celular) à farmácia de sua preferência.
              </p>
            </td>
          </tr>
          <tr>
            <td>
              {{> footer appName=appName supportEmail=supportEmail}}
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
