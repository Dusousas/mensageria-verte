<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Senha alterada</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f6f1e8;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="24" border="0">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width: 640px; background: #ffffff; border-radius: 14px; overflow: hidden; box-shadow: 0 4px 16px rgba(22, 59, 52, 0.08);">
          <tr>
            <td>
              {{> header preheader="Sua senha foi alterada com sucesso" appName=appName}}
            </td>
          </tr>
          <tr>
            <td style="padding: 26px 24px 12px 24px; font-family: Inter, Arial, sans-serif; color: #212529;">
              <h1 style="margin: 0 0 12px 0; font-size: 24px; line-height: 31px; color: #163b34;">Senha atualizada</h1>
              <p style="margin: 0; font-size: 15px; line-height: 24px; color: #3c4643;">
                Oi{{#if name}}, {{name}}{{/if}}. Confirmamos a alteracao da sua senha.
              </p>
            </td>
          </tr>
          <tr>
            <td style="padding: 18px 24px 26px 24px; font-family: Inter, Arial, sans-serif; color: #3c4643; font-size: 15px; line-height: 24px;">
              Se nao foi voce, recomendamos trocar a senha novamente e entrar em contato com o suporte imediatamente.
              {{#if loginUrl}}
              <div style="margin-top: 16px;">
                <a href="{{loginUrl}}" style="display: inline-block; background-color: #2a5654; color: #ffffff; text-decoration: none; font-family: Inter, Arial, sans-serif; font-weight: 600; font-size: 14px; line-height: 20px; padding: 12px 20px; border-radius: 10px;">
                  Acessar minha conta
                </a>
              </div>
              {{/if}}
            </td>
          </tr>
          <tr>
            <td>
              {{> footer appName=appName supportEmail=supportEmail}}
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
